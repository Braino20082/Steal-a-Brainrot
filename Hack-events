local evScroll = makeScroll(tabFrames["Events"], UDim2.fromScale(1,1), UDim2.fromOffset(0,0))

local function refreshEvents()
    for _, child in ipairs(evScroll:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextLabel") then child:Destroy() end
    end
    local count = 0
    for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            count += 1
            local row = Instance.new("Frame")
            row.Size=UDim2.new(1,0,0,46); row.BackgroundColor3=BG_MID
            row.BackgroundTransparency=0.2; row.BorderSizePixel=0
            row.LayoutOrder=count; row.ZIndex=6; row.Parent=evScroll
            local rc=Instance.new("UICorner"); rc.CornerRadius=UDim.new(0,8); rc.Parent=row
            local rs=Instance.new("UIStroke"); rs.Thickness=1; rs.Color=Color3.fromRGB(30,30,80); rs.Parent=row
            local lbl=Instance.new("TextLabel")
            lbl.Size=UDim2.new(1,-100,1,0); lbl.Position=UDim2.new(0,12,0,0)
            lbl.BackgroundTransparency=1; lbl.Text="🔗 "..obj.Name
            lbl.TextColor3=TEXT_WHITE; lbl.Font=Enum.Font.Gotham; lbl.TextSize=13
            lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.TextTruncate=Enum.TextTruncate.AtEnd
            lbl.ZIndex=7; lbl.Parent=row
            local fb,_=neonBtn(row,"Fire",UDim2.new(0,70,0,30),UDim2.new(1,-80,0.5,-15),NEON_CYAN,7)
            fb.TextSize=12
            local cap=obj
            fb.MouseButton1Click:Connect(function()
                local ok=pcall(function() cap:FireServer() end)
                if ok then
                    TweenService:Create(fb,TW_FAST,{BackgroundColor3=Color3.fromRGB(0,60,0)}):Play()
                    task.delay(0.6,function() TweenService:Create(fb,TW_FAST,{BackgroundColor3=Color3.fromRGB(15,15,40)}):Play() end)
                end
            end)
        end
    end
    if count == 0 then
        local e=Instance.new("TextLabel"); e.Size=UDim2.new(1,0,0,50)
        e.BackgroundTransparency=1; e.Text="Keine RemoteEvents gefunden"
        e.TextColor3=Color3.fromRGB(100,100,150); e.Font=Enum.Font.Gotham; e.TextSize=13; e.ZIndex=6; e.Parent=evScroll
    end
end

