-- ═══════════ EVENTS TAB ═══════════
local evScroll = scrollFrame(tabFrames["Events"], UDim2.fromScale(1,1), UDim2.fromOffset(0,0))

local function refreshEvents()
    for _,c in ipairs(evScroll:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
    end
    local n = 0
    for _,obj in ipairs(ReplicatedStorage:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            n += 1
            local row = Instance.new("Frame", evScroll)
            row.Size=UDim2.new(1,0,0,46); row.BackgroundColor3=BG_MID
            row.BackgroundTransparency=0.2; row.BorderSizePixel=0
            row.LayoutOrder=n; row.ZIndex=6
            Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
            local sk2=Instance.new("UIStroke",row); sk2.Thickness=1; sk2.Color=Color3.fromRGB(30,30,80)

            local lbl=Instance.new("TextLabel",row)
            lbl.Size=UDim2.new(1,-100,1,0); lbl.Position=UDim2.new(0,12,0,0)
            lbl.BackgroundTransparency=1; lbl.Text="🔗 "..obj.Name
            lbl.TextColor3=TEXT_WHITE; lbl.Font=Enum.Font.Gotham; lbl.TextSize=13
            lbl.TextXAlignment=Enum.TextXAlignment.Left
            lbl.TextTruncate=Enum.TextTruncate.AtEnd; lbl.ZIndex=7

            local fb,_=neonBtn(row,"Fire",UDim2.new(0,70,0,30),UDim2.new(1,-80,.5,-15),NEON_CYAN,7)
            fb.TextSize=12
            local cap=obj
            fb.MouseButton1Click:Connect(function()
                local ok=pcall(function() cap:FireServer() end)
                if ok then
                    TweenService:Create(fb,TW_FAST,{BackgroundColor3=Color3.fromRGB(0,60,0)}):Play()
                    task.delay(.6,function() TweenService:Create(fb,TW_FAST,{BackgroundColor3=Color3.fromRGB(15,15,40)}):Play() end)
                end
            end)
        end
    end
    if n==0 then
        local e=Instance.new("TextLabel",evScroll)
        e.Size=UDim2.new(1,0,0,50); e.BackgroundTransparency=1
        e.Text="No RemoteEvents in ReplicatedStorage"
        e.TextColor3=Color3.fromRGB(100,100,150); e.Font=Enum.Font.Gotham; e.TextSize=13; e.ZIndex=6
    end
end

local rb,_=neonBtn(tabFrames["Events"],"⟳ Refresh",UDim2.new(0,120,0,26),UDim2.new(1,-128,0,6),NEON_PURPLE,6)
rb.TextSize=12; rb.MouseButton1Click:Connect(refreshEvents)

