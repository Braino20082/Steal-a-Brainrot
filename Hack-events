-- Tabs
local Tabs = {}
local function createTab(name)
    local TabFrame = Instance.new("ScrollingFrame")
    TabFrame.Name = name .. "Tab"
    TabFrame.Size = UDim2.new(1, 0, 1, 0)
    TabFrame.BackgroundTransparency = 1
    TabFrame.ScrollBarThickness = 2
    TabFrame.Visible = false
    TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    TabFrame.Parent = Content
    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.Padding = UDim.new(0, 5)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = TabFrame
    Tabs[name] = TabFrame
    return TabFrame
end

local EventsTab = createTab("Events")
local TPTab = createTab("TP")
local TPATab = createTab("TPA")

-- Sidebar Buttons
local activeBtn = nil
local function createSidebarButton(name, order, icon)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.88, 0, 0, 42)
    btn.Position = UDim2.new(0.06, 0, 0, 10 + (order * 52))
    btn.BackgroundColor3 = BG_COLOR
    btn.Text = icon .. " " .. name
    btn.TextColor3 = TEXT_COLOR
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = Sidebar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

    btn.MouseButton1Click:Connect(function()
        for _, tab in pairs(Tabs) do tab.Visible = false end
        if Tabs[name] then Tabs[name].Visible = true end
        if activeBtn then
            TweenService:Create(activeBtn, TweenInfo.new(0.15), {BackgroundColor3 = BG_COLOR}):Play()
        end
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 0, 120)}):Play()
        activeBtn = btn
    end)
    return btn
end

local eventsBtn = createSidebarButton("Events", 0, "🔥")
local tpBtn = createSidebarButton("TP", 1, "🌀")
createSidebarButton("TPA", 2, "📍")

-- Content Button Helper
local function createContentButton(parent, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 38)
    btn.BackgroundColor3 = ACCENT_COLOR
    btn.Text = text
    btn.TextColor3 = TEXT_COLOR
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(70, 0, 100)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = ACCENT_COLOR}):Play()
    end)
    if callback then
        btn.MouseButton1Click:Connect(function()
            pcall(callback)
        end)
    end
    return btn
end

-- Events Tab
local function refreshEvents()
    for _, child in pairs(EventsTab:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then child:Destroy() end
    end
    local found = false
    pcall(function()
        for _, item in pairs(ReplicatedStorage:GetDescendants()) do
            if item:IsA("RemoteEvent") then
                found = true
                createContentButton(EventsTab, "🔥 Fire: " .. item.Name, function()
                    item:FireServer()
                end)
            end
        end
    end)
    if not found then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -10, 0, 35)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Keine RemoteEvents gefunden"
        lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 13
        lbl.Parent = EventsTab
    end
end

-- TP Tab
local function refreshPlayers()
    for _, child in pairs(TPTab:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextLabel") then child:Destroy() end
    end
    local found = false
    pcall(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= player then
                found = true
                local frame = Instance.new("Frame")
                frame.Size = UDim2.new(1, -10, 0, 52)
                frame.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
                frame.BorderSizePixel = 0
                frame.Parent = TPTab
                Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

                local nameLabel = Instance.new("TextLabel")
                nameLabel.Size = UDim2.new(0.6, 0, 1, 0)
                nameLabel.Position = UDim2.new(0, 10, 0, 0)
                nameLabel.BackgroundTransparency = 1
                nameLabel.Text = "👤 " .. (p.DisplayName or p.Name)
                nameLabel.TextColor3 = TEXT_COLOR
                nameLabel.Font = Enum.Font.GothamBold
                nameLabel.TextSize = 13
                nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                nameLabel.Parent = frame

                local tpButton = Instance.new("TextButton")
                tpButton.Size = UDim2.new(0, 65, 0, 32)
                tpButton.Position = UDim2.new(1, -75, 0.5, -16)
                tpButton.BackgroundColor3 = Color3.fromRGB(100, 0, 150)
                tpButton.Text = "🌀 TP"
                tpButton.TextColor3 = TEXT_COLOR
                tpButton.Font = Enum.Font.GothamBold
                tpButton.TextSize = 13
                tpButton.Parent = frame
                Instance.new("UICorner", tpButton).CornerRadius = UDim.new(0, 6)

                tpButton.MouseButton1Click:Connect(function()
                    pcall(function()
                        if p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                            and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                            player.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame + Vector3.new(2, 0, 0)
                        end
                    end)
                end)
            end
        end
    end)
    if not found then
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -10, 0, 35)
        lbl.BackgroundTransparency = 1
        lbl.Text = "Keine anderen Spieler gefunden"
        lbl.TextColor3 = Color3.fromRGB(150, 150, 150)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 13
        lbl.Parent = TPTab
    end
end

-- TPA Tab
local savedPositions = {}
local function buildTPAButtons()
    for _, child in pairs(TPATab:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    createContentButton(TPATab, "📍 Position speichern", function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local pos = player.Character.HumanoidRootPart.CFrame
            local idx = #savedPositions + 1
            table.insert(savedPositions, pos)
            createContentButton(TPATab, "🔁 TP zu Punkt " .. idx, function()
                pcall(function()
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                        player.Character.HumanoidRootPart.CFrame = pos
                    end
                end)
            end)
        end
    end)
    createContentButton(TPATab, "🗑️ Alle Punkte löschen", function()
        savedPositions = {}
        buildTPAButtons()
    end)
end
buildTPAButtons()

-- Öffnen / Schließen
local isOpen = false
local isTweening = false

local function closePanel()
    if isTweening then return end
    isTweening = true
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0)
    })
    tween:Play()
    tween.Completed:Connect(function()
        MainFrame.Visible = false
        isTweening = false
    end)
end

local function openPanel()
    if isTweening then return end
    isTweening = true
    refreshEvents()
    refreshPlayers()
    for _, tab in pairs(Tabs) do tab.Visible = false end
    EventsTab.Visible = true
    -- Events Button als aktiv markieren
    TweenService:Create(eventsBtn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 0, 120)}):Play()
    activeBtn = eventsBtn

    MainFrame.Visible = true
    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    MainFrame.Position = UDim2.new(0.5, 0, 0.5, 0)

    -- Animiert auf 50% des Bildschirms
    local tween = TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0.5, 0, 0.5, 0),
        Position = UDim2.new(0.25, 0, 0.25, 0)
    })
    tween:Play()
    tween.Completed:Connect(function() isTweening = false end)
end

local function toggle()
    isOpen = not isOpen
    if isOpen then openPanel() else closePanel() end
end

closeBtn.MouseButton1Click:Connect(function()
    isOpen = false
    closePanel()
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == TASTE then
        pcall(toggle)
    end
end)

-- Direkt beim Start öffnen
task.spawn(function()
    task.wait(0.3)
    pcall(openPanel)
    isOpen = true
end)

print("[BrainrotV1] ✅ Geladen. Taste 'O' zum Öffnen/Schließen.")
