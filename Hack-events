-- ═══════════ OPEN / CLOSE ═══════════
local function openPanel()
    panelOpen=true; refreshEvents(); refreshTP()
    Main.Size=UDim2.fromOffset(0,0); Main.Position=UDim2.new(.5,0,.5,0); Main.Visible=true
    TweenService:Create(Overlay,TW_OPEN,{BackgroundTransparency=0.55}):Play()
    TweenService:Create(Main,TW_OPEN,{Size=UDim2.fromOffset(720,450),Position=UDim2.new(.5,-360,.5,-225)}):Play()
end

local function closePanel()
    panelOpen=false
    TweenService:Create(Overlay,TW_CLOSE,{BackgroundTransparency=1}):Play()
    local t=TweenService:Create(Main,TW_CLOSE,{Size=UDim2.fromOffset(0,0),Position=UDim2.new(.5,0,.5,0)})
    t:Play()
    t.Completed:Connect(function() if not panelOpen then Main.Visible=false end end)
end

