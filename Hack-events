local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local LocalPlayer
repeat LocalPlayer = Players.LocalPlayer task.wait() until LocalPlayer
local PlayerGui
repeat PlayerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") task.wait() until PlayerGui

-- Altes entfernen
local old = PlayerGui:FindFirstChild("EventPanel")
if old then old:Destroy() end

-- Farben
local BG     = Color3.fromRGB(10, 10, 25)
local BG2    = Color3.fromRGB(18, 18, 40)
local CYAN   = Color3.fromRGB(0, 220, 255)
local WHITE  = Color3.fromRGB(220, 220, 255)

-- ScreenGui
local sg = Instance.new("ScreenGui")
sg.Name = "EventPanel"
sg.ResetOnSpawn = false
sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
pcall(function() sg.DisplayOrder = 999 end)
sg.Parent = PlayerGui

-- Hauptframe
local frame = Instance.new("Frame")
frame.Size = UDim2.fromOffset(500, 400)
frame.AnchorPoint = Vector2.new(0.5, 0.5)
frame.Position = UDim2.new(0.5, 0, 0.5, 0)
frame.BackgroundColor3 = BG
frame.BorderSizePixel = 0
frame.Parent = sg

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 12)
corner.Parent = frame

local stroke = Instance.new("UIStroke")
stroke.Color = CYAN
stroke.Thickness = 2
stroke.Parent = frame

-- Titel
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 44)
title.BackgroundColor3 = BG2
title.BorderSizePixel = 0
title.Text = "⚡  Remote Events"
title.TextColor3 = CYAN
title.Font = Enum.Font.GothamBold
title.TextSize = 17
title.TextXAlignment = Enum.TextXAlignment.Left
title.ZIndex = 2
title.Parent = frame

local titlePad = Instance.new("UIPadding")
titlePad.PaddingLeft = UDim.new(0, 14)
titlePad.Parent = title

local tc = Instance.new("UICorner")
tc.CornerRadius = UDim.new(0, 12)
tc.Parent = title

local tcFill = Instance.new("Frame")
tcFill.Size = UDim2.new(1, 0, 0, 12)
tcFill.Position = UDim2.new(0, 0, 1, -12)
tcFill.BackgroundColor3 = BG2
tcFill.BorderSizePixel = 0
tcFill.ZIndex = 2
tcFill.Parent = title

-- ScrollFrame
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -16, 1, -54)
scroll.Position = UDim2.new(0, 8, 0, 50)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 4
scroll.ScrollBarImageColor3 = CYAN
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.CanvasSize = UDim2.new()
scroll.ZIndex = 2
scroll.Parent = frame

local layout = Instance.new("UIListLayout")
layout.Padding = UDim.new(0, 6)
layout.SortOrder = Enum.SortOrder.LayoutOrder
layout.Parent = scroll

local pad = Instance.new("UIPadding")
pad.PaddingTop = UDim.new(0, 6)
pad.PaddingBottom = UDim.new(0, 6)
pad.Parent = scroll

-- Events laden
local count = 0
for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        count += 1

        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 44)
        row.BackgroundColor3 = BG2
        row.BorderSizePixel = 0
        row.LayoutOrder = count
        row.ZIndex = 3
        row.Parent = scroll

        local rc = Instance.new("UICorner")
        rc.CornerRadius = UDim.new(0, 8)
        rc.Parent = row

        local rs = Instance.new("UIStroke")
        rs.Color = Color3.fromRGB(30, 30, 80)
        rs.Thickness = 1
        rs.Parent = row

        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -110, 1, 0)
        lbl.Position = UDim2.new(0, 12, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = "🔗  " .. obj.Name
        lbl.TextColor3 = WHITE
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 13
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextTruncate = Enum.TextTruncate.AtEnd
        lbl.ZIndex = 4
        lbl.Parent = row

        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 80, 0, 30)
        btn.Position = UDim2.new(1, -88, 0.5, -15)
        btn.BackgroundColor3 = Color3.fromRGB(15, 15, 40)
        btn.Text = "Fire"
        btn.TextColor3 = CYAN
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 13
        btn.BorderSizePixel = 0
        btn.AutoButtonColor = false
        btn.ZIndex = 4
        btn.Parent = row

        local bc = Instance.new("UICorner")
        bc.CornerRadius = UDim.new(0, 7)
        bc.Parent = btn

        local bsk = Instance.new("UIStroke")
        bsk.Color = Color3.fromRGB(0, 100, 120)
        bsk.Thickness = 1.5
        bsk.Parent = btn

        local TW = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        btn.MouseEnter:Connect(function()
            TweenService:Create(btn, TW, {BackgroundColor3 = Color3.fromRGB(0, 50, 70)}):Play()
            TweenService:Create(bsk, TW, {Color = CYAN, Thickness = 2.5}):Play()
        end)
        btn.MouseLeave:Connect(function()
            TweenService:Create(btn, TW, {BackgroundColor3 = Color3.fromRGB(15,15,40)}):Play()
            TweenService:Create(bsk, TW, {Color = Color3.fromRGB(0,100,120), Thickness = 1.5}):Play()
        end)

        local capObj = obj
        local capRow = row
        btn.MouseButton1Click:Connect(function()
            pcall(function() capObj:FireServer() end)
            TweenService:Create(capRow, TW, {BackgroundColor3 = Color3.fromRGB(0, 50, 20)}):Play()
            task.delay(0.5, function()
                TweenService:Create(capRow, TW, {BackgroundColor3 = BG2}):Play()
            end)
        end)
    end
end

-- Leer-Anzeige
if count == 0 then
    local empty = Instance.new("TextLabel")
    empty.Size = UDim2.new(1, 0, 0, 50)
    empty.BackgroundTransparency = 1
    empty.Text = "Keine RemoteEvents in ReplicatedStorage gefunden."
    empty.TextColor3 = Color3.fromRGB(120, 120, 160)
    empty.Font = Enum.Font.Gotham
    empty.TextSize = 13
    empty.ZIndex = 3
    empty.Parent = scroll
end

print("✅ Event Panel geladen — " .. count .. " Events gefunden.")
