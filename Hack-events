local tabFrames  = {}
local tabBtns    = {}

for _, name in ipairs(TABS) do
    local f = Instance.new("Frame")
    f.Size                   = UDim2.fromScale(1, 1)
    f.BackgroundTransparency = 1
    f.Visible                = (name == "Events")
    f.ZIndex                 = 4
    f.Parent                 = Content
    tabFrames[name]          = f
end

local function selectTab(name)
    currentTab = name
    for _, n in ipairs(TABS) do
        tabFrames[n].Visible = (n == name)
        local btn = tabBtns[n]
        if not btn then continue end
        local sk = btn:FindFirstChildWhichIsA("UIStroke")
        local c  = TAB_COLORS[n]
        if n == name then
            TweenService:Create(btn, TW_FAST, {BackgroundColor3 = Color3.fromRGB(math.floor(c.R*60), math.floor(c.G*60), math.floor(c.B*60))}):Play()
            if sk then TweenService:Create(sk, TW_FAST, {Color = c, Thickness = 2.5}):Play() end
        else
            TweenService:Create(btn, TW_FAST, {BackgroundColor3 = Color3.fromRGB(15,15,40)}):Play()
            if sk then TweenService:Create(sk, TW_FAST, {Color = Color3.fromRGB(math.floor(c.R*255*0.3), math.floor(c.G*255*0.3), math.floor(c.B*255*0.3)), Thickness = 1.5}):Play() end
        end
    end
end

for _, name in ipairs(TABS) do
