local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Konfiguration
local TASTE = Enum.KeyCode.O
local NEON_COLOR = Color3.fromRGB(255, 0, 255) -- Magenta/Neon Pink
local BG_COLOR = Color3.fromRGB(15, 15, 20)
local ACCENT_COLOR = Color3.fromRGB(30, 30, 40)
local TEXT_COLOR = Color3.fromRGB(255, 255, 255)

-- GUI Erstellung
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "B-AdminPanel"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = playerGui

-- Blur Effekt
local Blur = Instance.new("BlurEffect")
Blur.Size = 0
Blur.Enabled = false
Blur.Parent = Lighting

-- Main Frame
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 600, 0, 400)
MainFrame.Position = UDim2.new(0.5, -300, 0.5, -200)
MainFrame.BackgroundColor3 = BG_COLOR
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true
MainFrame.Visible = false
MainFrame.Parent = ScreenGui

-- Corner & Border Glow
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 10)
UICorner.Parent = MainFrame

local UIStroke = Instance.new("UIStroke")
UIStroke.Color = NEON_COLOR
UIStroke.Thickness = 2
UIStroke.Transparency = 0.5
UIStroke.Parent = MainFrame

-- Animierter Border Effekt
task.spawn(function()
    while true do
        local t = tick()
        local hue = (t * 0.2) % 1
        UIStroke.Color = Color3.fromHSV(hue, 0.8, 1)
        task.wait()
    end
end)

-- Sidebar
local Sidebar = Instance.new("Frame")
Sidebar.Name = "Sidebar"
Sidebar.Size = UDim2.new(0, 150, 1, 0)
Sidebar.BackgroundColor3 = ACCENT_COLOR
Sidebar.BorderSizePixel = 0
Sidebar.Parent = MainFrame

local SidebarCorner = Instance.new("UICorner")
SidebarCorner.CornerRadius = UDim.new(0, 10)
SidebarCorner.Parent = Sidebar

-- Content Area
local Content = Instance.new("Frame")
Content.Name = "Content"
Content.Position = UDim2.new(0, 160, 0, 10)
Content.Size = UDim2.new(1, -170, 1, -20)
Content.BackgroundTransparency = 1
Content.Parent = MainFrame

-- Tabs Container
local Tabs = {}

local function createTab(name)
    local TabFrame = Instance.new("ScrollingFrame")
    TabFrame.Name = name .. "Tab"
    TabFrame.Size = UDim2.new(1, 0, 1, 0)
    TabFrame.BackgroundTransparency = 1
    TabFrame.ScrollBarThickness = 2
    TabFrame.Visible = false
    TabFrame.Parent = Content
    
    local UIListLayout = Instance.new("UIListLayout")
    UIListLayout.Padding = UDim.new(0, 5)
    UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    UIListLayout.Parent = TabFrame
    
    Tabs[name] = TabFrame
    return TabFrame
end

local EventsTab = createTab("Events")
local TPTab = createTab("TP")
local TPATab = createTab("TPA")

-- Sidebar Buttons
local function createSidebarButton(name, order)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "Btn"
    btn.Size = UDim2.new(0.9, 0, 0, 40)
    btn.Position = UDim2.new(0.05, 0, 0, 10 + (order * 50))
    btn.BackgroundColor3 = BG_COLOR
    btn.Text = name
    btn.TextColor3 = TEXT_COLOR
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 14
    btn.Parent = Sidebar
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = NEON_COLOR
    stroke.Thickness = 1
    stroke.Transparency = 0.8
    stroke.Parent = btn
    
    -- Hover Effekt
    btn.MouseEnter:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0, Thickness = 2}):Play()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0.8, Thickness = 1}):Play()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = BG_COLOR}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        for _, tab in pairs(Tabs) do tab.Visible = false end
        Tabs[name].Visible = true
    end)
end

createSidebarButton("Events", 0)
createSidebarButton("TP", 1)
createSidebarButton("TPA", 2)

-- Default Tab
Tabs["Events"].Visible = true

-- Hilfsfunktion für Buttons im Content
local function createContentButton(parent, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 35)
    btn.BackgroundColor3 = ACCENT_COLOR
    btn.Text = text
    btn.TextColor3 = TEXT_COLOR
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = NEON_COLOR
    stroke.Thickness = 1
    stroke.Transparency = 0.9
    stroke.Parent = btn
    
    btn.MouseEnter:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.2}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.9}):Play()
    end)
    
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- EVENTS TAB LOGIC
local function refreshEvents()
    for _, child in pairs(EventsTab:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, item in pairs(ReplicatedStorage:GetDescendants()) do
        if item:IsA("RemoteEvent") then
            createContentButton(EventsTab, "Fire: " .. item.Name, function()
                item:FireServer()
                print("Fired RemoteEvent: " .. item.Name)
            end)
        end
    end
end
refreshEvents()

-- TP TAB LOGIC
local function refreshPlayers()
    for _, child in pairs(TPTab:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, -10, 0, 50)
            frame.BackgroundTransparency = 1
            frame.Parent = TPTab
            
            local img = Instance.new("ImageLabel")
            img.Size = UDim2.new(0, 40, 0, 40)
            img.Position = UDim2.new(0, 5, 0, 5)
            img.BackgroundColor3 = ACCENT_COLOR
            img.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
            img.Parent = frame
            Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)
            
            local name = Instance.new("TextLabel")
            name.Size = UDim2.new(0.5, 0, 1, 0)
            name.Position = UDim2.new(0, 55, 0, 0)
            name.BackgroundTransparency = 1
            name.Text = p.DisplayName
            name.TextColor3 = TEXT_COLOR
            name.Font = Enum.Font.GothamBold
            name.TextXAlignment = Enum.TextXAlignment.Left
            name.Parent = frame
            
            createContentButton(frame, "Teleport", function()
                if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame
                end
            end).Size = UDim2.new(0, 100, 0, 30)
            frame:FindFirstChildOfClass("TextButton").Position = UDim2.new(1, -105, 0, 10)
        end
    end
end
Players.PlayerAdded:Connect(refreshPlayers)
Players.PlayerRemoving:Connect(refreshPlayers)
refreshPlayers()

-- TPA TAB LOGIC
local savedPositions = {}

local function createTPAControls()
    createContentButton(TPATab, "Aktuelle Position speichern", function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local pos = player.Character.HumanoidRootPart.CFrame
            local name = "Pos " .. (#savedPositions + 1)
            table.insert(savedPositions, {name = name, cf = pos})
            
            createContentButton(TPATab, "TP zu: " .. name, function()
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character.HumanoidRootPart.CFrame = pos
                end
            end)
        end
    end)
end
createTPAControls()

-- Open/Close Logic
local isOpen = false
local function toggle()
    isOpen = not isOpen
    
    if isOpen then
        MainFrame.Visible = true
        MainFrame.Position = UDim2.new(0.5, -300, 0.6, -200)
        MainFrame.BackgroundTransparency = 1
        UIStroke.Transparency = 1
        Sidebar.BackgroundTransparency = 1
        
        Blur.Enabled = true
        TweenService:Create(Blur, TweenInfo.new(0.5), {Size = 24}):Play()
        TweenService:Create(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -300, 0.5, -200), BackgroundTransparency = 0}):Play()
        TweenService:Create(UIStroke, TweenInfo.new(0.5), {Transparency = 0.5}):Play()
        TweenService:Create(Sidebar, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
        
        refreshEvents()
        refreshPlayers()
    else
        TweenService:Create(Blur, TweenInfo.new(0.3), {Size = 0}):Play()
        local t = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {Position = UDim2.new(0.5, -300, 0.6, -200), BackgroundTransparency = 1})
        TweenService:Create(UIStroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        TweenService:Create(Sidebar, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        
        t:Play()
        t.Completed:Wait()
        if not isOpen then
            MainFrame.Visible = false
            Blur.Enabled = false
        end
    end
end

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == TASTE then
        toggle()
    end
end)

print("B-AdminPanel geladen. Drücke 'O' zum Öffnen.")
