-- ═══════════ HELPERS ═══════════
local function neonBtn(parent, text, size, pos, color, zi)
    color = color or NEON_CYAN; zi = zi or 5
    local b = Instance.new("TextButton", parent)
    b.Size = size; b.Position = pos
    b.BackgroundColor3 = Color3.fromRGB(15,15,40)
    b.BackgroundTransparency = 0.1
    b.Text = text; b.TextColor3 = color
    b.Font = Enum.Font.GothamSemibold; b.TextSize = 13
    b.BorderSizePixel = 0; b.AutoButtonColor = false; b.ZIndex = zi
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 8)
    local sk = Instance.new("UIStroke", b)
    sk.Thickness = 1.5
    sk.Color = Color3.fromRGB(color.R*255*.4, color.G*255*.4, color.B*255*.4)
    b.MouseEnter:Connect(function()
        TweenService:Create(b,  TW_FAST, {BackgroundColor3 = Color3.fromRGB(
            math.clamp(math.floor(color.R*60),0,255),
            math.clamp(math.floor(color.G*60),0,255),
            math.clamp(math.floor(color.B*60),0,255))}):Play()
        TweenService:Create(sk, TW_FAST, {Color=color, Thickness=2.5}):Play()
        TweenService:Create(b,  TW_FAST, {TextColor3=Color3.new(1,1,1)}):Play()
    end)
    b.MouseLeave:Connect(function()
        TweenService:Create(b,  TW_FAST, {BackgroundColor3 = Color3.fromRGB(15,15,40)}):Play()
        TweenService:Create(sk, TW_FAST, {Color=Color3.fromRGB(color.R*255*.4,color.G*255*.4,color.B*255*.4), Thickness=1.5}):Play()
        TweenService:Create(b,  TW_FAST, {TextColor3 = color}):Play()
    end)
    return b, sk
end

local function scrollFrame(parent, size, pos)
    local s = Instance.new("ScrollingFrame", parent)
    s.Size = size; s.Position = pos
    s.BackgroundTransparency = 1; s.BorderSizePixel = 0
    s.ScrollBarThickness = 4; s.ScrollBarImageColor3 = NEON_CYAN
    s.AutomaticCanvasSize = Enum.AutomaticSize.Y
    s.CanvasSize = UDim2.new(); s.ZIndex = 5
    local l = Instance.new("UIListLayout", s)
    l.Padding = UDim.new(0,8); l.SortOrder = Enum.SortOrder.LayoutOrder
    local p = Instance.new("UIPadding", s)
    p.PaddingLeft=UDim.new(0,10); p.PaddingRight=UDim.new(0,10)
    p.PaddingTop=UDim.new(0,10);  p.PaddingBottom=UDim.new(0,10)
    return s
end

