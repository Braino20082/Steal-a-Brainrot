local tpScroll = scrollFrame(tabFrames["TP"], UDim2.fromScale(1,1), UDim2.fromOffset(0,0))

local function refreshTP()
    for _,c in ipairs(tpScroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    for i,plr in ipairs(Players:GetPlayers()) do
        local row=Instance.new("Frame",tpScroll)
        row.Size=UDim2.new(1,0,0,58); row.BackgroundColor3=BG_MID
        row.BackgroundTransparency=0.2; row.BorderSizePixel=0
        row.LayoutOrder=i; row.ZIndex=6
        Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
        local sk2=Instance.new("UIStroke",row); sk2.Thickness=1; sk2.Color=Color3.fromRGB(30,30,80)

        local img=Instance.new("ImageLabel",row)
        img.Size=UDim2.fromOffset(44,44); img.Position=UDim2.new(0,8,.5,-22)
        img.BackgroundColor3=Color3.fromRGB(20,20,50); img.BorderSizePixel=0; img.ZIndex=7
        Instance.new("UICorner",img).CornerRadius=UDim.new(1,0)
        local imgSk=Instance.new("UIStroke",img); imgSk.Thickness=1.5; imgSk.Color=NEON_PINK

        local uid=plr.UserId
        task.spawn(function()
            local ok,url=pcall(function()
                return Players:GetUserThumbnailAsync(uid,Enum.ThumbnailType.HeadShot,Enum.ThumbnailSize.Size48x48)
            end)
            if ok then img.Image=url end
        end)

        local nl=Instance.new("TextLabel",row)
        nl.Size=UDim2.new(1,-170,1,0); nl.Position=UDim2.new(0,60,0,0)
        nl.BackgroundTransparency=1; nl.Text=plr.DisplayName.."\n@"..plr.Name
        nl.TextColor3=TEXT_WHITE; nl.Font=Enum.Font.GothamSemibold; nl.TextSize=12
        nl.TextXAlignment=Enum.TextXAlignment.Left; nl.ZIndex=7

        local tb,_=neonBtn(row,"Teleport",UDim2.new(0,88,0,32),UDim2.new(1,-96,.5,-16),NEON_PINK,7)
        tb.TextSize=12
        local capPlr=plr
        tb.MouseButton1Click:Connect(function()
            local ch=LocalPlayer.Character; local tch=capPlr.Character
            if ch and tch then
                local h=ch:FindFirstChild("HumanoidRootPart"); local th=tch:FindFirstChild("HumanoidRootPart")
                if h and th then h.CFrame=th.CFrame+Vector3.new(2,0,2) end
            end
        end)
    end
end

