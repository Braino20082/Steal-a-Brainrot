-- STEAL SYSTEM
-- ══════════════════════════════════════════════════════
local stealCooldown = false
local stealCount = 0

local function FindAllBrainrots()
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            for _, name in ipairs(BRAINROT_NAMES) do
                if obj.Name:lower():find(name:lower()) then
                    table.insert(found, obj)
                    break
                end
            end
        end
    end
    return found
end

local function FindBestBrainrot()
    local list = FindAllBrainrots()
    if #list == 0 then return nil end
    table.sort(list, function(a, b)
        local sA = (a:IsA("BasePart") and a.Size.Magnitude) or 1
        local sB = (b:IsA("BasePart") and b.Size.Magnitude) or 1
        return sA > sB
    end)
    return list[1]
end

local function GetRichestPlayer()
    local best, bestVal = nil, -1
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local stats = player:FindFirstChild("leaderstats")
            local val = 0
            if stats then
                for _, v in ipairs(stats:GetChildren()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        val = val + v.Value
                    end
                end
            end
            if val == 0 and player:FindFirstChild("Backpack") then
                val = #player.Backpack:GetChildren()
            end
            if val > bestVal then
                bestVal = val
                best = player
            end
        end
    end
    return best
end

local function DoSteal(obj)
    if stealCooldown then return false end
    local hrp = GetHRP()
    if not hrp or not obj or not obj.Parent then return false end

    stealCooldown = true

    local originalCFrame = hrp.CFrame
    local targetCF
    if obj:IsA("BasePart") then
        targetCF = obj.CFrame
    elseif obj:IsA("Model") and obj.PrimaryPart then
        targetCF = obj.PrimaryPart.CFrame
    end

    if targetCF then
        hrp.CFrame = targetCF * CFrame.new(0, 3, 0)
        task.wait(0.05)
    end

    pcall(function()
        if obj and obj.Parent then
            obj.Parent = LocalPlayer.Backpack
            stealCount = stealCount + 1
        end
    end)

    if CFG.AutoTP then
        task.wait(0.05)
        TeleportToSpawn()
    else
        -- Return to original position if not teleporting to spawn
        hrp.CFrame = originalCFrame
    end

    task.delay(CFG.StealCooldown, function()
        stealCooldown = false
    end)
    return true
end

-- ══════════════════════════════════════════════════════
-- AUTO STEAL HEARTBEAT
-- ══════════════════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    if stealCooldown then return end

    if CFG.AutoStealBest then
        local richest = GetRichestPlayer()
        if richest and richest.Character then
            local hrp = GetHRP()
            local rhrp = richest.Character:FindFirstChild("HumanoidRootPart")
            if hrp and rhrp then
                stealCooldown = true
                hrp.CFrame = rhrp.CFrame * CFrame.new(0, 0, -3)
                task.wait(0.1)
                
                local itemsStolen = 0
                if richest:FindFirstChild("Backpack") then
                    for _, tool in ipairs(richest.Backpack:GetChildren()) do
                        pcall(function() tool.Parent = LocalPlayer.Backpack; itemsStolen = itemsStolen + 1 end)
                    end
                end
                if richest.Character then
                    for _, tool in ipairs(richest.Character:GetChildren()) do
                        if tool:IsA("Tool") then
                            pcall(function() tool.Parent = LocalPlayer.Backpack; itemsStolen = itemsStolen + 1 end)
                        end
                    end
                end
                stealCount = stealCount + itemsStolen

                if CFG.AutoTP then
                    TeleportToSpawn()
                end
                
                task.delay(CFG.StealCooldown + 0.5, function() stealCooldown = false end)
            end
        end
    elseif CFG.AutoStealAll then
        local hrp = GetHRP()
        if hrp then
            local list = FindAllBrainrots()
            for _, obj in ipairs(list) do
                local pos
                if obj:IsA("BasePart") then
                    pos = obj.Position
                elseif obj:IsA("Model") and obj.PrimaryPart then
                    pos = obj.PrimaryPart.Position
                end
                if pos and (hrp.Position - pos).Magnitude <= CFG.StealRadius then
                    if DoSteal(obj) then
                        break -- Only steal one item per frame to avoid spam
                    end
                end
            end
        end
    end
end)

