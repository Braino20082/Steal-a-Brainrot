local function MakeSwitch(parent, defaultOn, goldMode)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 44, 0, 22)
    bg.BorderSizePixel = 0
    bg.Parent = parent
    UICorner(bg, 100)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = bg
    UICorner(knob, 100)

    local state = defaultOn or false
    
    local function UpdateVisuals()
        local onColor = goldMode and Color3.fromRGB(200,120,10) or Color3.fromRGB(120,50,240)
        local offColor = goldMode and Color3.fromRGB(55,35,8) or Color3.fromRGB(40,32,70)
        local knobOnPos = UDim2.new(0,25,0.5,-8)
        local knobOffPos = UDim2.new(0,3,0.5,-8)
        
        bg.BackgroundColor3 = state and onColor or offColor
        knob.Position = state and knobOnPos or knobOffPos
    end

    local function Toggle(forcedState)
        state = (forcedState ~= nil) and forcedState or not state
        UpdateVisuals()
        return state
    end
    
    UpdateVisuals() -- Set initial state
    return bg, knob, Toggle, function() return state end
end

