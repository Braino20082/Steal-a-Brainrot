local function UIPad(p, t, l, r, b)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop    = UDim.new(0, t or 8)
    pad.PaddingLeft   = UDim.new(0, l or 10)
    pad.PaddingRight  = UDim.new(0, r or 10)
    pad.PaddingBottom = UDim.new(0, b or 8)
    pad.Parent = p
