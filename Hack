-- Fly System
local Fly = { bodyGyro = nil, bodyVelocity = nil }
function ToggleFly(enabled)
    local hrp = Utility.GetHRP()
    if not hrp then return end
    if enabled then
        Fly.bodyGyro = Utility.Create("BodyGyro", { P = 9e4, Parent = hrp, MaxTorque = Vector3.new(9e9, 9e9, 9e9), CFrame = hrp.CFrame })
        Fly.bodyVelocity = Utility.Create("BodyVelocity", { P = 9e4, Parent = hrp, MaxForce = Vector3.new(9e9, 9e9, 9e9), Velocity = Vector3.new(0, 0, 0) })
        FeatureStates.Fly.loop = Services.RunService.RenderStepped:Connect(function()
            Utility.SafeCall(function()
                if not Fly.bodyGyro or not Fly.bodyGyro.Parent then return end
                local speed = FeatureStates.Fly.value
                Fly.bodyGyro.CFrame = Camera.CFrame
                Fly.bodyVelocity.Velocity = ((Camera.CFrame.lookVector * (Services.UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)) + (Camera.CFrame.lookVector * -1 * (Services.UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)) + (Camera.CFrame.rightVector * (Services.UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0)) + (Camera.CFrame.rightVector * -1 * (Services.UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)) + (Camera.CFrame.upVector * (Services.UserInputService:IsKeyDown(Enum.KeyCode.Space) and 1 or 0)) + (Camera.CFrame.upVector * -1 * (Services.UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and 1 or 0))).unit * speed
            end)
        end)
    else
        if Fly.loop then Fly.loop:Disconnect() end
        if Fly.bodyGyro then Fly.bodyGyro:Destroy() end
        if Fly.bodyVelocity then Fly.bodyVelocity:Destroy() end
    end
end

