            math.clamp(colorB.R*255 - 20, 0, 255),
            math.clamp(colorB.G*255 - 20, 0, 255),
            math.clamp(colorB.B*255 - 20, 0, 255)
        )
    end)
    Btn.MouseButton1Up:Connect(function()
        Btn.BackgroundColor3 = colorA
    end)
    Btn.MouseButton1Click:Connect(function()
        if callback then
            local ok, err = pcall(callback)
            if not ok then warn("[BrainrotAdmin] Button callback error:", err) end
        end
    end)
    return Btn
end

local function MakeStat(parent, val, lbl, color)
    local Box = Instance.new("Frame")
    Box.Size = UDim2.new(0, 1, 0, 60) Box.AutomaticSize = Enum.AutomaticSize.X
    Box.BackgroundColor3 = Color3.fromRGB(6,6,18) Box.BorderSizePixel = 0 Box.Parent = parent
    UICorner(Box, 10) UIStroke(Box, Color3.fromRGB(40,28,80), 1)
    UIPad(Box, 8, 14, 14, 6)
    local vl = Instance.new("UIListLayout")
    vl.HorizontalAlignment = Enum.HorizontalAlignment.Center
    vl.VerticalAlignment = Enum.VerticalAlignment.Center
    vl.Parent = Box
    local vLbl = Instance.new("TextLabel")
    vLbl.BackgroundTransparency = 1 vLbl.Text = tostring(val)
    vLbl.TextSize = 20 vLbl.Font = Enum.Font.GothamBold
    vLbl.TextColor3 = color or Color3.fromRGB(168,85,247) vLbl.Parent = Box
    local nLbl = Instance.new("TextLabel")
    nLbl.BackgroundTransparency = 1 nLbl.Text = lbl
    nLbl.TextSize = 9 nLbl.Font = Enum.Font.GothamBold
    nLbl.TextColor3 = Color3.fromRGB(80,65,110) nLbl.Parent = Box
    return Box, vLbl
end

