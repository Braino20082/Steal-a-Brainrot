--[[
    B-StealABrainrot GUI
    Erstellt für den Nutzer
    Features: Auto Steal, Auto Farm, Speed, Jump, ESP, Noclip
]]

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/7Lib/7Lib/main/7Lib.lua"))()
local Window = Library.CreateLib("B-Steal A Brainrot Hub", "DarkTheme")

-- Variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local VirtualUser = game:GetService("VirtualUser")

local AutoSteal = false
local AutoFarm = false
local WalkSpeed = 16
local JumpPower = 50
local Noclip = false

-- Anti-AFK
LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- Tabs
local MainTab = Window:NewTab("Main")
local MovementTab = Window:NewTab("Movement")
local VisualsTab = Window:NewTab("Visuals")
local CreditsTab = Window:NewTab("Credits")

-- Main Features
local MainSection = MainTab:NewSection("Automation")

MainSection:NewToggle("Auto Steal", "Stiehlt automatisch Brainrots von anderen Plots", function(state)
    AutoSteal = state
    while AutoSteal do
        task.wait(0.1)
        pcall(function()
            -- Suche nach Plots und Podien
            for _, v in pairs(game:GetService("Workspace").Plots:GetChildren()) do
                if v:FindFirstChild("Podium") and v.Owner.Value ~= LocalPlayer.Name then
                    -- Simuliere Interaktion oder feuere Remote (Spiel-spezifisch)
                    -- Da Remotes variieren können, nutzen wir eine generische Annäherung/Klick-Logik
                    local podium = v.Podium
                    if (LocalPlayer.Character.HumanoidRootPart.Position - podium.Position).Magnitude < 15 then
                        -- Hier würde normalerweise ein RemoteEvent gefeuert werden
                        -- Beispiel: game:GetService("ReplicatedStorage").Remotes.Steal:FireServer(v.Name)
                        fireclickdetector(podium:FindFirstChildOfClass("ClickDetector"))
                    end
                end
            end
        end)
    end
end)

MainSection:NewToggle("Auto Farm", "Sammelt automatisch Drops ein", function(state)
    AutoFarm = state
    while AutoFarm do
        task.wait(0.1)
        pcall(function()
            for _, v in pairs(game:GetService("Workspace").Drops:GetChildren()) do
                if v:IsA("BasePart") then
                    v.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
                end
            end
        end)
    end
end)

MainSection:NewButton("Load PusarX Hub", "Lädt das beliebte PusarX Skript", function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Estevansit0/KJJK/refs/heads/main/PusarX-loader.lua"))()
end)

MainSection:NewButton("Load Light Hub", "Lädt das Light Hub Skript", function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/LightHub-V2/sabscriptop/refs/heads/main/opscript"))()
end)

-- Movement Features
local MoveSection = MovementTab:NewSection("Character")

MoveSection:NewSlider("WalkSpeed", "Ändert deine Geschwindigkeit", 250, 16, function(s)
    WalkSpeed = s
    LocalPlayer.Character.Humanoid.WalkSpeed = s
end)

MoveSection:NewSlider("JumpPower", "Ändert deine Sprungkraft", 500, 50, function(s)
    JumpPower = s
    LocalPlayer.Character.Humanoid.JumpPower = s
end)

MoveSection:NewToggle("Noclip", "Gehe durch Wände", function(state)
    Noclip = state
    RunService.Stepped:Connect(function()
        if Noclip then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("BasePart") then
                    v.CanCollide = false
                end
            end
        end
    end)
end)

-- Visuals
local VisualSection = VisualsTab:NewSection("ESP")

VisualSection:NewButton("Player ESP", "Zeigt Spieler durch Wände an", function()
    -- Einfaches Box ESP
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local Highlight = Instance.new("Highlight")
            Highlight.Parent = player.Character
            Highlight.FillColor = Color3.fromRGB(255, 0, 0)
            Highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        end
    end
end)

-- Credits
CreditsTab:NewSection("Erstellt von Manus für dich")
CreditsTab:NewButton("Skript kopieren", "Kopiert das Skript in die Zwischenablage", function()
    setclipboard("loadstring(game:HttpGet('https://raw.githubusercontent.com/LightHub-V2/sabscriptop/refs/heads/main/opscript'))()")
end)

Library:Notify("B-Steal A Brainrot Hub geladen!", "Viel Spaß beim Hacken!", 5)
