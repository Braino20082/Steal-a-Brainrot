local function MakeSwitch(parent, defaultOn, goldMode)
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0, 44, 0, 22)
    if goldMode then
        bg.BackgroundColor3 = defaultOn and Color3.fromRGB(180,100,10) or Color3.fromRGB(55,35,8)
    else
        bg.BackgroundColor3 = defaultOn and Color3.fromRGB(100,40,220) or Color3.fromRGB(40,32,70)
    end
    bg.BorderSizePixel = 0
    bg.Parent = parent
    UICorner(bg, 100)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = defaultOn and UDim2.new(0, 25, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = bg
    UICorner(knob, 100)

    local state = defaultOn or false

    local function Toggle(forcedState)
        state = (forcedState ~= nil) and forcedState or (not state)
        if goldMode then
            bg.BackgroundColor3 = state and Color3.fromRGB(200,120,10) or Color3.fromRGB(55,35,8)
        else
            bg.BackgroundColor3 = state and Color3.fromRGB(120,50,240) or Color3.fromRGB(40,32,70)
        end
        knob.Position = state and UDim2.new(0,25,0.5,-8) or UDim2.new(0,3,0.5,-8)
        return state
    end

    return bg, knob, Toggle, function() return state end
end

