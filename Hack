--  STEAL SYSTEM
-- ══════════════════════════════════════════════════════
local stealCooldownActive = false
local stealCount = 0

-- Sucht alle Brainrot-Objekte im Workspace
local function FindAllBrainrots()
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            for _, name in ipairs(BRAINROT_NAMES) do
                if obj.Name:lower():find(name:lower()) then
                    table.insert(found, obj)
                    break
                end
            end
        end
    end
    return found
end

-- Findet den wertvollsten Brainrot (nach Name / Größe)
local function FindBestBrainrot()
    local brainrots = FindAllBrainrots()
    if #brainrots == 0 then return nil end
    -- Nimm den größten / ersten als "besten"
    table.sort(brainrots, function(a, b)
        local sA = a:IsA("BasePart") and a.Size.Magnitude or 1
        local sB = b:IsA("BasePart") and b.Size.Magnitude or 1
        return sA > sB
    end)
    return brainrots[1]
end

-- Findet den Spieler mit den meisten Brainrots
local function GetRichestPlayer()
    local best, bestVal = nil, -1
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            -- Versuche leaderstats / value zu lesen
            local stats = player:FindFirstChild("leaderstats")
            local val = 0
            if stats then
                for _, v in ipairs(stats:GetChildren()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        val = val + v.Value
                    end
                end
            end
            if val > bestVal then
                bestVal = val
                best = player
            end
        end
    end
    return best
end

-- Führt einen einzelnen Steal durch
local function DoSteal(obj)
    if stealCooldownActive then return false end
    local hrp = GetHRP()
    if not hrp then return false end

    -- Zum Objekt teleportieren
    local targetPos
    if obj:IsA("BasePart") then
        targetPos = obj.CFrame
    elseif obj:IsA("Model") then
        local root = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
        if root then targetPos = root.CFrame end
    end

    if targetPos then
        hrp.CFrame = targetPos * CFrame.new(0, 2, 0)
        task.wait(0.1)
    end

    -- Objekt "klauen" (aus Workspace entfernen)
    local success = pcall(function()
        if obj and obj.Parent then
            obj.Parent = LocalPlayer.Backpack
        end
    end)

    stealCount = stealCount + 1

    -- Nach Steal → Spawn TP (wenn aktiviert)
    if CFG.AutoTP and CFG.SpawnCFrame then
        task.wait(0.05)
        TeleportToSpawn()
    end

    -- Cooldown
    stealCooldownActive = true
    task.delay(CFG.StealCooldown, function()
        stealCooldownActive = false
    end)

    return true
end

-- ══════════════════════════════════════════════════════
--  AUTO STEAL LOOP
-- ══════════════════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    -- AUTO STEAL ALL
    if CFG.AutoStealAll then
        local hrp = GetHRP()
        if hrp and not stealCooldownActive then
            local brainrots = FindAllBrainrots()
            for _, obj in ipairs(brainrots) do
                local pos
                if obj:IsA("BasePart") then pos = obj.Position
                elseif obj:IsA("Model") and obj.PrimaryPart then pos = obj.PrimaryPart.Position end
                if pos then
                    local dist = (hrp.Position - pos).Magnitude
                    if dist <= CFG.StealRadius then
                        DoSteal(obj)
                        break -- 1 pro Frame, Cooldown regelt Speed
                    end
                end
            end
        end
    end

    -- AUTO STEAL BEST (von reichstem Spieler)
    if CFG.AutoStealBest then
        if not stealCooldownActive then
            local richest = GetRichestPlayer()
            if richest and richest.Character then
                local hrp = GetHRP()
                local rhrp = richest.Character:FindFirstChild("HumanoidRootPart")
                if hrp and rhrp then
                    -- TP zum Spieler, dann stehlen was er trägt
                    hrp.CFrame = rhrp.CFrame * CFrame.new(0, 0, -3)
                    task.wait(0.1)
                    -- Sein Backpack leeren
                    for _, tool in ipairs(richest.Backpack:GetChildren()) do
                        local ok = pcall(function()
                            tool.Parent = LocalPlayer.Backpack
                        end)
                        if ok then
                            stealCount = stealCount + 1
                        end
                    end
                    -- Auch getragene Tools klauen
                    if richest.Character then
                        for _, tool in ipairs(richest.Character:GetChildren()) do
                            if tool:IsA("Tool") then
                                local ok = pcall(function()
                                    tool.Parent = LocalPlayer.Backpack
                                end)
                                if ok then stealCount = stealCount + 1 end
                            end
                        end
                    end
                    if CFG.AutoTP and CFG.SpawnCFrame then
                        TeleportToSpawn()
                    end
                    stealCooldownActive = true
                    task.delay(CFG.StealCooldown + 0.5, function()
                        stealCooldownActive = false
                    end)
                end
            end
        end
    end
end)

