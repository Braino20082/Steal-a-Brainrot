-- ESP System
local ESP = { Players = {}, Brainrots = {} }
local function UpdateESP()
    -- Clear old ESP
    for item, espElements in pairs(ESP.Players) do if not item or not item.Parent then for _, v in pairs(espElements) do v:Destroy() end; ESP.Players[item] = nil end end
    for item, espElements in pairs(ESP.Brainrots) do if not item or not item.Parent then for _, v in pairs(espElements) do v:Destroy() end; ESP.Brainrots[item] = nil end end

    -- Player ESP
    if FeatureStates.ESPPlayers.enabled then
        for _, player in pairs(Services.Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and not ESP.Players[player.Character] then
                local char = player.Character
                local head = char:FindFirstChild("Head")
                if head then
                    local billboard = Utility.Create("BillboardGui", { Adornee = head, Size = UDim2.new(0, 100, 0, 50), StudsOffset = Vector3.new(0, 2, 0), AlwaysOnTop = true, Parent = PlayerGui })
                    local text = Utility.Create("TextLabel", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = player.Name, TextColor3 = FeatureStates.ESPPlayers.color, TextSize = 14, Font = Enum.Font.GothamBold, Parent = billboard })
                    local highlight = Utility.Create("Highlight", { FillColor = FeatureStates.ESPPlayers.color, FillTransparency = 0.7, OutlineTransparency = 1, Parent = char, Enabled = true })
                    ESP.Players[char] = { billboard, highlight }
                end
            end
        end
    else
        for _, elements in pairs(ESP.Players) do for _, v in pairs(elements) do v:Destroy() end end; ESP.Players = {}
    end

    -- Brainrot ESP
    if FeatureStates.ESPBrainrots.enabled then
        for _, item in pairs(Services.Workspace:GetDescendants()) do
            if item:IsA("BasePart") and item.Name:match("Brainrot") and not ESP.Brainrots[item] then
                local billboard = Utility.Create("BillboardGui", { Adornee = item, Size = UDim2.new(0, 100, 0, 50), StudsOffset = Vector3.new(0, 2, 0), AlwaysOnTop = true, Parent = PlayerGui })
                local text = Utility.Create("TextLabel", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = item.Name, TextColor3 = FeatureStates.ESPBrainrots.color, TextSize = 12, Font = Enum.Font.Gotham, Parent = billboard })
                -- BoxHandleAdornment is often unavailable, Highlight is a safer alternative
                local highlight = Utility.Create("Highlight", { FillColor = FeatureStates.ESPBrainrots.color, FillTransparency = 0.8, OutlineColor = FeatureStates.ESPBrainrots.color, OutlineTransparency = 0.5, Parent = item, Enabled = true })
                ESP.Brainrots[item] = { billboard, highlight }
            end
        end
    else
        for _, elements in pairs(ESP.Brainrots) do for _, v in pairs(elements) do v:Destroy() end end; ESP.Brainrots = {}
    end
end
