-- ══════════════════════════════════════════════════════
local ESPObjects = {}

local function RemoveESP(player)
    if ESPObjects[player] then
        for _, obj in ipairs(ESPObjects[player]) do
            pcall(function() obj:Destroy() end)
        end
        ESPObjects[player] = nil
    end
end

local function AddESP(player)
    if player == LocalPlayer then return end
    RemoveESP(player)

    local function BuildForChar(char)
        if not char then return end
        local hrp = char:FindFirstChildWhichIsA("BasePart")
        if not hrp then
            hrp = char:WaitForChild("HumanoidRootPart", 5)
        end
        if not hrp then return end

        local objs = {}

        -- SelectionBox (Highlight)
        local box = Instance.new("SelectionBox")
        box.Adornee            = char
        box.Color3             = CFG.ESPColor
        box.LineThickness      = 0.04
        box.SurfaceTransparency = 0.75
        box.SurfaceColor3      = CFG.ESPColor
        box.Parent             = workspace
        table.insert(objs, box)

        -- BillboardGui (Name + Distanz)
        local billboard = Instance.new("BillboardGui")
        billboard.Adornee      = hrp
        billboard.Size         = UDim2.new(0, 140, 0, 36)
        billboard.StudsOffset  = Vector3.new(0, 3.5, 0)
        billboard.AlwaysOnTop  = true
        billboard.Parent       = workspace

        local nameLbl = Instance.new("TextLabel")
        nameLbl.Size           = UDim2.new(1, 0, 0, 18)
        nameLbl.Position       = UDim2.new(0, 0, 0, 0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text           = player.Name
        nameLbl.TextColor3     = CFG.ESPColor
        nameLbl.TextSize       = 13
        nameLbl.Font           = Enum.Font.GothamBold
        nameLbl.TextStrokeTransparency = 0.4
        nameLbl.Parent         = billboard

        local distLbl = Instance.new("TextLabel")
        distLbl.Size           = UDim2.new(1, 0, 0, 14)
        distLbl.Position       = UDim2.new(0, 0, 0, 18)
        distLbl.BackgroundTransparency = 1
        distLbl.TextColor3     = Color3.fromRGB(200, 200, 200)
        distLbl.TextSize       = 11
        distLbl.Font           = Enum.Font.GothamBold
        distLbl.TextStrokeTransparency = 0.5
        distLbl.Parent         = billboard

        table.insert(objs, billboard)
        ESPObjects[player] = objs

        -- Distanz updaten
        RunService.Heartbeat:Connect(function()
            if not CFG.ESPEnabled or not ESPObjects[player] then return end
            local myHRP = GetHRP()
            if myHRP and hrp and hrp.Parent then
                local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                distLbl.Text = dist .. " studs"
                box.Color3   = CFG.ESPColor
                box.SurfaceColor3 = CFG.ESPColor
                nameLbl.TextColor3 = CFG.ESPColor
            end
        end)
    end

    if player.Character then BuildForChar(player.Character) end
    player.CharacterAdded:Connect(BuildForChar)
end

-- ESP toggle handler
local function SetESP(enabled)
    CFG.ESPEnabled = enabled
    if enabled then
        for _, p in ipairs(Players:GetPlayers()) do
            AddESP(p)
        end
        Players.PlayerAdded:Connect(AddESP)
    else
        for _, p in ipairs(Players:GetPlayers()) do
            RemoveESP(p)
        end
    end
end

Players.PlayerRemoving:Connect(RemoveESP)

