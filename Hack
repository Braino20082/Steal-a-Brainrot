-- ESP SYSTEM
-- ══════════════════════════════════════════════════════
local ESPObjects = {}

local function RemoveESP(player)
    if ESPObjects[player] then
        for _, obj in ipairs(ESPObjects[player]) do
            pcall(function() if obj and obj.Parent then obj:Destroy() end end)
        end
        ESPObjects[player] = nil
    end
end

local function AddESP(player)
    if player == LocalPlayer then return end
    RemoveESP(player)
    local objs = {}

    local function BuildForChar(char)
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- Selection Box
        local box = Instance.new("SelectionBox")
        box.Adornee = char
        box.Color3 = CFG.ESPColor
        box.LineThickness = 0.04
        box.SurfaceTransparency = 0.75
        box.SurfaceColor3 = CFG.ESPColor
        box.Parent = PlayerGui -- Parent to PlayerGui for better management
        table.insert(objs, box)

        -- Billboard (Name + Distance)
        local bb = Instance.new("BillboardGui")
        bb.Adornee = hrp
        bb.Size = UDim2.new(0, 140, 0, 36)
        bb.StudsOffset = Vector3.new(0, 3.5, 0)
        bb.AlwaysOnTop = true
        bb.Parent = PlayerGui -- Parent to PlayerGui
        
        local nLbl = Instance.new("TextLabel")
        nLbl.Size = UDim2.new(1, 0, 1, 0)
        nLbl.BackgroundTransparency = 1
        nLbl.Text = player.Name
        nLbl.TextColor3 = CFG.ESPColor
        nLbl.TextSize = 13
        nLbl.Font = Enum.Font.GothamBold
        nLbl.TextStrokeTransparency = 0.4
        nLbl.Parent = bb

        local dLbl = Instance.new("TextLabel")
        dLbl.Size = UDim2.new(1, 0, 0, 14)
        dLbl.Position = UDim2.new(0, 0, 1, -14)
        dLbl.BackgroundTransparency = 1
        dLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
        dLbl.TextSize = 11
        dLbl.Font = Enum.Font.GothamBold
        dLbl.TextStrokeTransparency = 0.5
        dLbl.Parent = bb
        
        table.insert(objs, bb)
        ESPObjects[player] = objs

        -- Live update distance
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not CFG.ESPEnabled or not ESPObjects[player] or not bb.Parent then
                conn:Disconnect()
                return
            end
            
            bb.Enabled = CFG.ShowNames

            local myHRP = GetHRP()
            if myHRP and hrp and hrp.Parent then
                local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
                pcall(function()
                    dLbl.Text = dist .. " studs"
                    box.Color3 = CFG.ESPColor
                    box.SurfaceColor3 = CFG.ESPColor
                    nLbl.TextColor3 = CFG.ESPColor
                end)
            else
                -- If character is gone, clean up
                RemoveESP(player)
                conn:Disconnect()
            end
        end)
    end

    if player.Character then
        BuildForChar(player.Character)
    end
    player.CharacterAdded:Connect(BuildForChar)
end

local function SetESP(enabled)
    CFG.ESPEnabled = enabled
    if enabled then
        for _, p in ipairs(Players:GetPlayers()) do
            AddESP(p)
        end
    else
        for _, p in ipairs(Players:GetPlayers()) do
            RemoveESP(p)
        end
    end
end

Players.PlayerAdded:Connect(function(p)
    if CFG.ESPEnabled then
        AddESP(p)
    end
end)
Players.PlayerRemoving:Connect(RemoveESP)

