local function CreateToggle(parent, featureName, text)
    local feature = FeatureStates[featureName]
    local row = Utility.Create("Frame", { Size = UDim2.new(1, 0, 0, 30), BackgroundTransparency = 1, Parent = parent })
    local label = Utility.Create("TextLabel", { Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, -50, 1, 0), BackgroundTransparency = 1, Font = Enum.Font.Gotham, Text = text, TextColor3 = Theme.TextSecondary, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left, Parent = row })
    local switch = Utility.Create("TextButton", { Position = UDim2.new(1, -40, 0.5, -12.5), Size = UDim2.new(0, 40, 0, 25), BackgroundColor3 = feature.enabled and Theme.Success or Theme.Border, Text = "", Parent = row })
    local knob = Utility.Create("Frame", { Position = feature.enabled and UDim2.new(1, -18, 0.5, -7.5) or UDim2.new(0, 3, 0.5, -7.5), Size = UDim2.new(0, 15, 0, 15), BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0, Parent = switch })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = switch })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = knob })
    
    switch.MouseButton1Click:Connect(function()
        feature.enabled = not feature.enabled
        switch.BackgroundColor3 = feature.enabled and Theme.Success or Theme.Border
        Utility.Tween(knob, { Position = feature.enabled and UDim2.new(1, -18, 0.5, -7.5) or UDim2.new(0, 3, 0.5, -7.5) }, 0.2)
        if featureName == "Fly" then ToggleFly(feature.enabled)
        elseif featureName == "Noclip" then ToggleNoclip(feature.enabled)
        elseif featureName:match("ESP") then -- No action needed here, heartbeat handles it
        else
            local hrp = Utility.GetHRP()
            if hrp and hrp.Parent and hrp.Parent:FindFirstChild("Humanoid") then
                if featureName == "WalkSpeed" then hrp.Parent.Humanoid.WalkSpeed = feature.enabled and feature.value or 16 end
                if featureName == "JumpPower" then hrp.Parent.Humanoid.JumpPower = feature.enabled and feature.value or 50 end
            end
        end
    end)
end

local function CreateSlider(parent, featureName, text)
    local feature = FeatureStates[featureName]
    local row = Utility.Create("Frame", { Size = UDim2.new(1, 0, 0, 40), BackgroundTransparency = 1, Parent = parent })
    local label = Utility.Create("TextLabel", { Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, 0, 0, 15), BackgroundTransparency = 1, Font = Enum.Font.Gotham, Text = text .. ": " .. feature.value, TextColor3 = Theme.TextSecondary, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = row })
    local back = Utility.Create("Frame", { Position = UDim2.new(0, 0, 0, 20), Size = UDim2.new(1, 0, 0, 8), BackgroundColor3 = Theme.Background, BorderSizePixel = 0, Parent = row })
    local fill = Utility.Create("Frame", { Size = UDim2.new(feature.value / feature.maxValue, 0, 1, 0), BackgroundColor3 = Theme.Primary, BorderSizePixel = 0, Parent = back })
    local drag = Utility.Create("TextButton", { Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", Parent = back })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = back })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })

    local function updateSlider(input)
        local relativeX = math.clamp((input.Position.X - back.AbsolutePosition.X) / back.AbsoluteSize.X, 0, 1)
        local newValue = math.floor(relativeX * feature.maxValue)
        feature.value = newValue
        label.Text = text .. ": " .. newValue
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        if feature.enabled then
            local hrp = Utility.GetHRP()
            if hrp and hrp.Parent and hrp.Parent:FindFirstChild("Humanoid") then
                if featureName == "WalkSpeed" then hrp.Parent.Humanoid.WalkSpeed = newValue end
                if featureName == "JumpPower" then hrp.Parent.Humanoid.JumpPower = newValue end
            end
        end
    end
    local connection
    drag.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then updateSlider(input); connection = Services.UserInputService.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement then updateSlider(i) end end) end end)
    drag.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 and connection then connection:Disconnect() end end)
end

